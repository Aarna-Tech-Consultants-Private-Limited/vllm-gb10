# =============================================================================
# vLLM GB10 -- Multi-Node Worker Node Environment Variables
# Source this on each Ray WORKER node before joining the cluster.
#
# IMPORTANT: Set VLLM_HOST_IP to THIS node's QSFP IP before sourcing.
#
# Usage:
#   source ~/vllm-env/bin/activate
#   export VLLM_HOST_IP=192.168.100.11    # <-- Your QSFP IP (NOT the head's)
#   source configs/multi-node-worker.env
#   ray start --address=<HEAD_QSFP_IP>:6379 --num-gpus=1
# =============================================================================

# -- Virtualenv activation (if not already active) --
VENV_DIR="${VENV_DIR:-$HOME/vllm-env}"
if [[ -z "${VIRTUAL_ENV:-}" ]]; then
    source "$VENV_DIR/bin/activate"
fi

# -- VLLM_HOST_IP (Fix 3: Ray IP consistency) --
# Must be set to THIS node's QSFP IP (not the head node's IP).
if [[ -z "${VLLM_HOST_IP:-}" ]]; then
    echo "[WARN] VLLM_HOST_IP not set. Set it to this node's QSFP IP:"
    echo "       export VLLM_HOST_IP=192.168.100.11"
fi

# -- Custom NCCL (must come first in LD_LIBRARY_PATH) --
NCCL_LIB="$HOME/nccl/build/lib"
CUDA_RUNTIME_LIB="$(python3 -c 'import nvidia.cuda_runtime; import os; print(os.path.join(os.path.dirname(nvidia.cuda_runtime.__file__), "lib"))' 2>/dev/null || echo "")"
export LD_LIBRARY_PATH="${NCCL_LIB}:${CUDA_RUNTIME_LIB}:/usr/local/cuda/lib64:${LD_LIBRARY_PATH:-}"

# -- Ray unified memory fix (Fix 7) --
export RAY_memory_usage_threshold=1.0

# -- NCCL environment variables (Fix 4) --
export NCCL_SOCKET_IFNAME=enp1s0f0np0    # Force QSFP primary interface
export UCX_NET_DEVICES=enp1s0f0np0        # UCX transport also uses QSFP
export NCCL_NET_GDR_LEVEL=SYS             # GPU Direct RDMA level
export NCCL_P2P_DISABLE=1                 # No P2P (separate physical nodes)
export NCCL_IB_DISABLE=1                  # No InfiniBand (using Socket transport)
export NCCL_DEBUG=INFO                    # Debug logging (set to WARN for production)

# -- HuggingFace offline mode --
export HF_HUB_OFFLINE=1
